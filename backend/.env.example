DJANGO_SECRET_KEY=change-me
# Production: dat False. De trong/True chi dung khi phat trien cuc bo.
DJANGO_DEBUG=True
# Production (Render): ten host duoc Render cap, vd training-saas-xxxx.onrender.com
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Supabase Postgres connection string (Project Settings > Database > Connection string > URI)
DATABASE_URL=postgresql://postgres:PASSWORD@HOST:5432/postgres

# Origin (co scheme) cua frontend duoc phep goi API - dev: Vite; production: URL Vercel
CORS_ALLOWED_ORIGINS=http://localhost:5173
# Origin (co scheme) duoc tin cay cho CSRF (Django admin) - production: URL Vercel
# vd: CSRF_TRUSTED_ORIGINS=https://training-saas.vercel.app
CSRF_TRUSTED_ORIGINS=

# CLS API (he thong LMS ngoai) - dung cho sync_cls
CLS_SECRET_KEY=your-cls-secret-key
CLS_API_BASE=https://eapiv4.cls.vn/api/HRM
CLS_EXAM_START_DATE=2024-01-01
CLS_PROBATION_EXAM_TYPES=NV,10N,15N,30N
CLS_ONBOARDING_PASS_SCORE=80

# Nguon tuyen dung (CSV export Google Sheet: File > Share > Publish to web > CSV) - dung cho sync_recruitment
RECRUITMENT_SOURCE_CSV_URL=https://docs.google.com/spreadsheets/d/xxx/pub?output=csv

# Supabase Storage - luu anh minh chung dao tao + bien ban PDF
# Lay o Supabase Dashboard > Project Settings > API (Project URL + service_role key)
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key
SUPABASE_STORAGE_BUCKET=training-evidence

# Phu cap/Hoa hong trainer - port CommissionService.gs (gia tri mac dinh)
COMMISSION_AMOUNT=300000
COMMISSION_SKILL_THRESHOLD=85
COMMISSION_EXAM_THRESHOLD=80
COMMISSION_WORKED_DAYS=30
# COMMISSION_RESTAURANT_ALLOWLIST=NH001,NH002
KPI_TARGET_PER_MONTH=3

# Thu viec - port Config.gs PROBATION_S_DAYS/PROBATION_O_DAYS (gia tri mac dinh)
PROBATION_S_DAYS=15
PROBATION_O_DAYS=60
PROBATION_DEADLINE_WARN_DAYS=10
